---
// HeroCollection component
export interface Props {
	title?: string;
	subtitle?: string;
	imageUrl?: string;
	imageAlt?: string;
}

const { 
	title = "COLLECTION", 
	subtitle = "EXPLORE THE COLLECTION",
	imageUrl = "https://images.unsplash.com/photo-1539571696357-5a69c17a67c6?w=800&h=1000&fit=crop",
	imageAlt = "Photography"
} = Astro.props;
---

<section id="hero-collection">
	<div class="hero-content">
        <div class="hero-left">
            <h2 class="hero-title">{title}</h2>
            <div class="hero-text">
                {subtitle}
            </div>
		</div>
		<div class="hero-right">
            <div class="hero-image">
                <img src={imageUrl} alt={imageAlt} />
            </div>
		</div>
	</div>
</section>

<style>
	#hero-collection {
		min-height: 80vh;
		display: flex;
		flex-direction: column;
		background: #e8e8e8;
	}

	.hero-title-section {
		width: 100%;
		padding: 4rem 3rem 2rem;
		display: flex;
		justify-content: center;
		align-items: center;
	}

	.hero-title {
		font-size: clamp(5rem, 5vw, 20rem);
		font-weight: 900;
		margin: 0;
		letter-spacing: -0.03em;
		line-height: 0.85;
		color: #2a2a2a;
		text-transform: uppercase;
	}

	.hero-content {
		flex: 1;
		display: grid;
		grid-template-columns: minmax(auto, 50%) 1fr;
		gap: 3rem;
		padding: 2rem 3rem 4rem;
	}

	.hero-left {
        flex: 1;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
	}

	.hero-image {
		width: 100%;
		height: 100%;
	}

	.hero-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.hero-right {
        flex: 1;
		display: flex;
		align-items: flex-end;
		justify-content: flex-start;
	}

	.hero-text {
		font-size: clamp(1.5rem, 3vw, 3rem);
		font-weight: 100;
		margin: 0;
		letter-spacing: -0.02em;
		line-height: 1;
		color: #2a2a2a;
        font-family: 'Cutive Mono', monospace;
	}

	@media (max-width: 1024px) {
		.hero-content {
			grid-template-columns: 1fr;
			gap: 2rem;
		}

		.hero-title-section {
			padding: 3rem 2rem 1.5rem;
		}

		.hero-content {
			padding: 1.5rem 2rem 3rem;
		}

		.hero-title {
			font-size: clamp(4rem, 20vw, 8rem);
		}

		.hero-text h2 {
			font-size: clamp(1.25rem, 5vw, 2rem);
		}

		.hero-right {
			align-items: flex-start;
		}
	}

	@media (max-width: 768px) {
		.hero-title-section {
			padding: 2rem 1.5rem 1rem;
		}

		.hero-content {
			padding: 1rem 1.5rem 2rem;
		}
	}
</style>