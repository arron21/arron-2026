<footer class="tui-statusbar black-168 white-255-text">
        <ul>
                <li><a href="/about" class="white-255-text">About</a></li>
                <li><a href="/web-development" class="white-255-text">Web Dev</a></li>
                <li><a href="/photography" class="white-255-text">Photography</a></li>
                <li><a href="/contact" class="white-255-text">Contact</a></li>
                <li><a href="https://github.com/arron21" class="white-255-text">GitHub</a></li>
