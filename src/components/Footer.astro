<style>
        footer {
                display: flex;
                flex-direction: column;
                justify-content: center;
                align-items: center;
                padding: 10px 8px;
                width: 100%;
                gap: 0.5rem;
        }

        footer ul {
                list-style: none;
                margin: 0;
                padding: 0;
                display: flex;
                flex-wrap: wrap;
                justify-content: center;
                gap: 1rem;
        }

        @media (min-width: 768px) {
                footer {
                        flex-direction: row;
                        justify-content: space-between;
                        padding: 2px 8px;
                        gap: 0.25rem;
                }
        }

        footer a:hover {
                text-decoration: underline;
        }

        footer span {
                font-size: 0.85rem;
        }
</style>
