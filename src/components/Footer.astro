---
// Footer component
---

<footer>
	<div class="footer-content">
		<div class="footer-logo">Arron McCrory</div>
		<div class="footer-links">
			<div class="footer-column">
				<h3>EXPLORE</h3>
				<a href="/about">About</a>
				<a href="/work">Work</a>
				<a href="/contact">Contact</a>
			</div>
			<div class="footer-column">
				<h3>CONNECT</h3>
				<a href="https://github.com/arron21">GitHub</a>
				<a href="https://www.linkedin.com/in/arronmccrory/">LinkedIn</a>
				<a href="https://wellfound.com/u/arron-mccrory">Wellfound</a>
				<a href="https://docs.google.com/document/d/1M1YJs4lePV7VkBOMQuWYUardPQqvpTrGbppKsocG-g0/edit?usp=sharing">Resume</a>
			</div>
		</div>
	</div>
	<div class="footer-bottom">
		<p>&copy; {new Date().getFullYear()} Arron McCrory. All rights reserved.</p>
	</div>
</footer>

<style>
	footer {
		margin-top: auto;
		background: #1a1a1a;
		color: white;
		padding: 4rem 3rem 2rem;
	}

	.footer-content {
		max-width: 1400px;
		margin: 0 auto;
		display: flex;
		justify-content: space-between;
		margin-bottom: 3rem;
	}

	.footer-logo {
		font-size: 1.5rem;
		font-weight: 700;
		letter-spacing: 0.05em;
	}

	.footer-links {
		display: flex;
		gap: 6rem;
	}

	.footer-column h3 {
		font-size: 0.75rem;
		font-weight: 600;
		letter-spacing: 0.1em;
		margin: 0 0 1rem 0;
		opacity: 0.5;
	}

	.footer-column {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.footer-column a {
		color: white;
		text-decoration: none;
		font-size: 0.9375rem;
		transition: opacity 0.2s;
	}

	.footer-column a:hover {
		opacity: 0.6;
	}

	.footer-bottom {
		max-width: 1400px;
		margin: 0 auto;
		padding-top: 2rem;
		border-top: 1px solid rgba(255, 255, 255, 0.1);
	}

	.footer-bottom p {
		margin: 0;
		font-size: 0.875rem;
		opacity: 0.5;
	}

	@media (max-width: 768px) {
		footer {
			padding: 3rem 1.5rem 2rem;
		}

		.footer-content {
			flex-direction: column;
			gap: 3rem;
		}

		.footer-links {
			gap: 3rem;
		}
	}
</style>