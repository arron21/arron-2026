---
// src/pages/index.astro (or a component file)
import astroLogo from '../assets/astro.svg';
import Hero from './Hero.astro';
import HeroCollection from './HeroCollection.astro';
import Footer from './Footer.astro';

// You'd typically import your collections data here if it were in a separate file.
// For now, the content is kept within the template.

// Note: The `Arron McCrory` strings seemed like a logo/brand name,
// and the various pieces of text were consolidated.
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Arron McCrory | LA-Based Photography</title>
    </head>
<body>
    <div id="container">


        <Hero />

        <div class="hero-divider"></div>

        <HeroCollection 
            title="VIVISTEP" 
            subtitle="URBAN LANDSCAPES & ARCHITECTURAL FORMS"
            imageUrl="https://images.unsplash.com/photo-1449824913935-59a10b8d2000?w=800&h=1000&fit=crop"
            imageAlt="Vivistep Collection - Urban Architecture"
        />

        <div class="hero-divider"></div>

        <HeroCollection 
            title="FALL" 
            subtitle="SEASONAL TRANSITIONS & NATURAL LIGHT"
            imageUrl="https://images.unsplash.com/photo-1478131143081-80f7f84ca84d?w=800&h=1000&fit=crop"
            imageAlt="Fall Collection - Autumn Photography"
        />

        <div class="hero-divider"></div>

        <HeroCollection 
            title="STILL LIFE" 
            subtitle="MINIMALIST STUDIES IN FORM & COMPOSITION"
            imageUrl="https://images.unsplash.com/photo-1494173853739-c21f58b16055?w=800&h=1000&fit=crop"
            imageAlt="Still Life Collection - Minimalist Photography"
        />

        <div class="hero-divider"></div>

        <HeroCollection 
            title="SERVICES" 
            subtitle="COMPREHENSIVE PHOTOGRAPHY SERVICES"
            imageUrl="https://images.unsplash.com/photo-1516035069371-29a1b244cc32?w=800&h=1000&fit=crop"
            imageAlt="Photography Services - Professional Work"
        />

    </div>

    <Footer />
</body>
</html>

<style>
    /* Reset and general styles */
    :root {
        --color-primary: #1a1a1a;
        --color-secondary: #333;
        --color-text-light: #666;
    }
    body {
        font-family: sans-serif; /* Use a better font in a real project */
        margin: 0;
        padding: 0;
        color: var(--color-primary);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
    }

    /* Header */
    header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        max-width: 1400px;
        margin: 0 auto;
        width: 100%;
        padding: 1.5rem 3rem;
        position: sticky;
        top: 0;
        background: white;
        z-index: 10;
        border-bottom: 1px solid rgba(0, 0, 0, 0.05);
    }
    .logo {
        font-size: 1.5rem;
        font-weight: 700;
        letter-spacing: 0.05em;
    }
    nav {
        display: flex;
        gap: 3rem;
    }
    nav a {
        color: var(--color-primary);
        text-decoration: none;
        font-weight: 500;
        letter-spacing: 0.05em;
        transition: opacity 0.2s;
    }
    nav a:hover {
        opacity: 0.7;
    }

    /* Hero Dividers */
    .hero-divider {
        width: 100%;
        height: 2px;
        background: #000;
        margin: 0;
        border: none;
    }

    /* Collections */
    .collections {
        max-width: 1400px;
        width: 100%;
        margin: 0 auto;
        padding: 4rem 3rem;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 3rem;
        flex-wrap: wrap; /* Added based on media query */
    }
    .collection-card {
        background: white;
        max-width: 100%;
        padding: 2.5rem;
        border: 1px solid rgba(0, 0, 0, 0.08);
        display: flex;
        flex-direction: column;
        transition: box-shadow 0.3s;
    }
    .collection-card:hover {
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    }
    .collection-header {
        margin-bottom: 1.5rem;
    }
    .collection-header h2 {
        font-size: 1.125rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        margin: 0;
    }
    .collection-description {
        font-size: 0.9375rem;
        line-height: 1.7;
        color: var(--color-text-light);
        margin-bottom: 2rem;
        flex-grow: 1;
    }
    .collection-link {
        color: var(--color-primary);
        text-decoration: none;
        font-size: 0.875rem;
        font-weight: 600;
        letter-spacing: 0.05em;
        transition: opacity 0.2s;
        align-self: flex-start;
        /* For multiple links in a card (like in the news section) */
        display: block;
        margin-top: 0.5rem;
    }
    .collection-link:first-of-type {
        margin-top: 0;
    }
    .collection-link:hover {
        opacity: 0.6;
    }

    /* News Section - Reusing card style */
    #news {
        max-width: 1400px;
        margin: 0 auto;
        width: 100%;
        padding: 0 3rem 4rem;
    }
    #news .collection-card {
        padding: 2.5rem;
    }

    /* Media Queries */
    @media (max-width: 768px) {
        header { padding: 1rem 1.5rem; }
        nav { gap: 1.5rem; }
        nav a { font-size: 0.75rem; }

        #hero { padding: 4rem 1.5rem; }
        #hero h1 { font-size: 3rem; }
        #hero h2 { font-size: 1rem; }
        .cta-button { font-size: 0.875rem; }

        .collections {
            padding: 2rem 1.5rem;
            grid-template-columns: 1fr;
            gap: 2rem;
        }
        #news {
            padding: 0 1.5rem 2rem;
        }
        .collection-card { padding: 2rem; }
    }
    /* Added based on your original max-height media query */
    @media screen and (max-height: 368px) {
        /* Hiding CTA button for very short screens */
        .cta-button { display: none; }
    }
</style>