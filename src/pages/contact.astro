---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<div class="tui-window blue-168 tui-page-window">
		<fieldset class="tui-fieldset white-255-border">
			<legend class="white-255-text">Contact</legend>
			<p class="white-255-text">
				<a href="/" class="cyan-255-text">&larr; Back to Home</a>
			</p>
			<form name="contact" method="POST" data-netlify="true" action="/success" class="contact-form">
				<div class="form-group">
					<label class="white-255-text" for="email">Email</label>
					<input class="tui-input" type="email" id="email" name="email" required />
				</div>
				<div class="form-group">
					<label class="white-255-text" for="name">Name</label>
					<input class="tui-input" type="text" id="name" name="name" required />
				</div>
				<div class="form-group">
					<label class="white-255-text" for="message">Your message</label>
					<textarea class="tui-input" id="message" name="message" rows="5" required></textarea>
				</div>
				<button type="submit" class="tui-button cyan-168 black-text">[ Send ]</button>
			</form>
		</fieldset>
	</div>
</Layout>

<style>
	.contact-form {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}
	.form-group {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}
	.tui-input {
		width: 100%;
	}
</style>
