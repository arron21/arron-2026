<style>
main {
margin: auto;
padding: 1rem;
max-width: 800px;
color: #333;
font-family: system-ui, sans-serif;
}
h1 {
font-size: 3rem;
font-weight: 700;
line-height: 1;
margin-bottom: 0.5em;
}
h2 {
font-size: 1.5rem;
color: #666;
margin-bottom: 1em;
}
p {
line-height: 1.6;
margin-bottom: 2em;
}
section {
margin-bottom: 3rem;
}
ul {
list-style: none;
padding: 0;
display: flex;
gap: 1rem;
flex-wrap: wrap;
}
.brands {
align-items: center;
justify-content: space-around;
gap: 2rem;
margin-top: 1.5rem;
}
.brands img {
width: 140px;
height: 48px;
object-fit: contain;
filter: grayscale(100%);
opacity: 0.7;
transition: all 0.2s ease-in-out;
}
.brands img:hover {
filter: grayscale(0%);
opacity: 1;
}
a {
color: #0056b3;
text-decoration: none;
}
a:hover {
text-decoration: underline;
}
</style>
