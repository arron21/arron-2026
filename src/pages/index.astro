---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<div class="tui-window blue-168" style="margin: 2rem auto; max-width: 700px; display: block;">
		<fieldset class="tui-fieldset white-255-border">
			<legend class="white-255-text">Welcome</legend>
			<h1 class="white-255-text">Hello, I'm Arron</h1>
			<h2 class="cyan-255-text">Full Stack Software Engineer</h2>
			<p class="white-255-text">
				With a passion for creating efficient, scalable, and intuitive digital experiences, I specialize
				in building robust applications that bring ideas to life. From frontend to backend, I craft
				solutions with precision, keeping the user experience at the forefront.
			</p>
		</fieldset>
	</div>

	<div class="tui-window black-168" style="margin: 0 auto 2rem; max-width: 700px; display: block;">
		<fieldset class="tui-fieldset white-168-border">
			<legend class="white-168-text">Navigate</legend>
			<ul class="nav-list">
				<li><a href="/web-development" class="tui-button cyan-168 black-text">[ Web Development ]</a></li>
				<li><a href="/photography" class="tui-button cyan-168 black-text">[ Photography ]</a></li>
				<li><a href="/about" class="tui-button cyan-168 black-text">[ About ]</a></li>
				<li><a href="/contact" class="tui-button cyan-168 black-text">[ Contact ]</a></li>
			</ul>
		</fieldset>
	</div>
</Layout>

<style>
	.nav-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
	}

	.nav-list a {
		text-decoration: none;
		display: inline-block;
	}
</style>
